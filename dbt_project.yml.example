name: 'your_project_name'
version: '1.0.0'
config-version: 2

profile: 'your_synapse_profile'

# Directory configuration
model-paths: ["models"]
test-paths: ["tests"]
macro-paths: ["macros"]
analysis-paths: ["analysis"]
seed-paths: ["data"]
snapshot-paths: ["snapshots"]

target-path: "target"
clean-targets:
  - "target"
  - "dbt_packages"
  - "logs"

# ============================================================================
# SCD2 DIMENSIONS CONFIGURATION
# ============================================================================
# Define all SCD2 dimensions here. Each entry creates 4 models + 1 test:
# - <name>__history.sql (insert-only history table)
# - <name>__candidate.sql (view with valid_to/is_current)
# - <name>__published.sql (approval-gated view)
# - <name>__gates.sql (consolidated gate test)
#
# The scd2_generate_shims macro reads this config and creates one-line shims
# in models/scd2/generated/ and tests/generated/
#
# Usage: dbt --quiet run-operation scd2_generate_shims | sh
# ============================================================================

vars:
  scd2_dimensions:
    # Example dimension 1: Customer dimension
    - name: dim_customer
      source: stg_customer
      natural_key: customer_id
      change_date_column: _landing_extract_date    # must be DATE type
      hash_column: attribute_hash                   # must be non-NULL varchar
      surrogate_key: dim_customer_sk                # optional; default: <name>_sk
      dist_column: customer_id                      # optional; default: first natural_key
      natural_key_cast: nvarchar(400)               # optional; default: nvarchar(400)
      dedupe_order_by: attribute_hash               # optional; default: hash_column
      volume_guard_factor: 0.5                      # optional; default: 0.5 (50% threshold)
      volume_guard_window: 7                        # optional; default: 7 (days)
      presentation_exclude:                         # optional; hide from published view
        - _batch_id
        - _loaded_at
        - attribute_hash

    # Example dimension 2: Product dimension (composite natural key)
    - name: dim_product
      source: stg_product
      natural_key:                                  # composite key (list)
        - product_id
        - version
      change_date_column: effective_date
      hash_column: content_hash
      dist_column: product_id                       # distribute by first key column
      presentation_exclude:
        - content_hash

    # Example dimension 3: Location dimension (simple key)
    - name: dim_location
      source: stg_location
      natural_key: location_id
      change_date_column: as_of_date
      hash_column: attribute_hash

# ============================================================================
# MODEL CONFIGURATION
# ============================================================================

models:
  your_project_name:
    # Staging layer (incoming data)
    staging:
      +materialized: view
      +schema: staging
      +tags: ["staging"]

    # SCD2 mart layer
    scd2:
      +schema: mart
      +persist_docs:
        relation: true
        columns: true

      # Hand-authored shims/docs
      +tags: ["scd2"]

      # Generated shims (auto-created by scd2_generate_shims)
      generated:
        +tags: ["scd2", "generated"]
        +schema: mart

tests:
  your_project_name:
    # Generated gate tests (auto-created by scd2_generate_shims)
    generated:
      +schema: audit
      +tags: ["scd2", "scd2_gate", "generated"]

# ============================================================================
# HOOKS: Approval gating and publication
# ============================================================================
# These hooks wire up the batch approval machinery:
#
# on-run-start:
#   1. scd2_generate_shims() - refresh generated shims from vars
#   2. scd2_bootstrap_audit() - ensure approval tables exist
#
# on-run-end:
#   1. scd2_approve_batches() - approve successful batches (gate check)
#                             - refresh published tables via CTAS+RENAME
#
# IMPORTANT: Use 'dbt build' (not 'dbt run') so gate tests execute
# ============================================================================

on-run-start:
  # Ensure all generated shims match current vars.scd2_dimensions
  - "{{ scd2_generate_shims() }}"
  # Ensure approval tables exist
  - "{{ scd2_bootstrap_audit() }}"

on-run-end:
  # Approve batches that passed all gate tests, refresh published tables
  - "{{ scd2_approve_batches(results) }}"

# ============================================================================
# SEEDS (optional static reference data)
# ============================================================================

seeds:
  your_project_name:
    +tags: ["reference"]

# ============================================================================
# SNAPSHOTS (optional for other SCD2 tracking)
# ============================================================================
# Note: The SCD2 dimensions macro handles SCD2 Type 2 natively.
# Snapshots are separate and optional for other use cases.

snapshots:
  your_project_name:
    +tags: ["snapshot"]

# ============================================================================
# QUOTING (required for Synapse reserved words)
# ============================================================================
# Synapse Dedicated SQL Pool requires identifier quoting for reserved words

quoting:
  identifier: false
  schema: false

# ============================================================================
# SYNAPSE-SPECIFIC DEFAULTS
# ============================================================================
# These apply to all models unless overridden per-model

models:
  your_project_name:
    +pre-hook: "{{ on_build_start(execute) }}"
    +post-hook: "{{ on_build_end(execute) }}"

# ============================================================================
# ANALYSIS & DOCS
# ============================================================================

analysis-paths: ["analysis"]

# ============================================================================
# DEVELOPMENT ENVIRONMENT OVERRIDES
# ============================================================================
# Uncomment to use different config during development

# {%- if target.name == 'dev' -%}
# vars:
#   scd2_dimensions:
#     # Limit to one dimension for faster dev iteration
#     - name: dim_customer
#       source: stg_customer
#       natural_key: customer_id
#       change_date_column: _landing_extract_date
#       hash_column: attribute_hash
# {%- endif -%}

# ============================================================================
# USAGE GUIDE
# ============================================================================
#
# 1. SETUP (first time):
#    a. Update profile to point to your Synapse Dedicated SQL Pool
#    b. Update vars.scd2_dimensions with your dimensions
#    c. Create staging models (stg_*) that load extract data
#    d. Run: dbt --quiet run-operation scd2_generate_shims | sh
#    e. Commit the generated shim files
#
# 2. ADD NEW DIMENSION:
#    a. Add entry to vars.scd2_dimensions
#    b. Create corresponding staging model (stg_<name>)
#    c. Run: dbt --quiet run-operation scd2_generate_shims | sh
#    d. Commit changes
#
# 3. RUN NIGHTLY LOAD:
#    a. Use 'dbt build' (not 'dbt run'):
#       dbt build --select scd2_*
#    b. This runs models + tests
#    c. Approval gate blocks publication if tests fail
#    d. CTAS+RENAME swap publishes only approved data
#
# 4. DEBUG FAILURES:
#    a. Check gate test results in audit.scd2_gate_test__* table
#    b. Review dbt test output for which check(s) failed
#    c. Fix staging data or dimension config
#    d. Re-run 'dbt build'
#
# 5. ROLLBACK (if needed):
#    a. dbt run-operation scd2_rollback --args '{"model_name": "dim_<name>__history", "to_datetime": "2026-07-01"}'
#    b. Review dry-run output
#    c. Re-run without dry_run=true to execute
#    d. dbt run-operation scd2_refresh_published will be called automatically
#
# 6. RESTORE (undo rollback):
#    a. dbt run-operation scd2_restore_last_rollback --args '{"model_name": "dim_<name>__history"}'
#    b. This re-approves rolled-back batches
#
# ============================================================================
# REQUIREMENTS
# ============================================================================
#
# Synapse Dedicated SQL Pool:
#   - Staging models must have:
#     * Natural key column(s) - non-NULL, uniquely identifies entity
#     * change_date_column - DATE type (not DATETIME)
#     * attribute_hash - MD5 varchar, non-NULL
#     * All other columns are SCD2 attributes (max 4000 chars for nvarchar)
#   - No unsupported types: text, ntext, xml, geography, etc.
#   - No (max) types: varchar must be ≤ 8000, nvarchar ≤ 4000
#
# dbt invocation:
#   - Always use 'dbt build' not 'dbt run' (ensures tests execute)
#   - Can select subset: dbt build --select scd2_dim_customer*
#   - Parallelization: threads config sets concurrency (default 4)
#
# ============================================================================
